# ============================================
# AIcountant Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================

# ============================================
# SUPABASE CONFIGURATION (Required for Auth & Database)
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# WARNING: Keep the service_role key secret! Only use server-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key

# ============================================
# STRIPE API KEYS (Optional - for payments)
# ============================================
# Test Environment (for development)
STRIPE_SECRET_KEY=sk_test_your_test_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key

# Production Environment (for production)
# STRIPE_SECRET_KEY=sk_live_your_live_key
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_live_key

# Webhook Secret (optional, for receiving payment status updates)
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Set to 'true' to enable demo mode without Supabase
DEMO_MODE=false

# Base URL for your application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SECURITY CONFIGURATION
# ============================================
# JWT Secret (if using custom JWT implementation)
# JWT_SECRET=your-jwt-secret-key

# Session Timeout in hours
SESSION_TIMEOUT=24

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# SMTP settings for sending emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@aicountant.com

# ============================================
# LOGGING CONFIGURATION (Optional)
# ============================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log to file (true/false)
LOG_TO_FILE=false
# LOG_FILE_PATH=./logs/app.log
