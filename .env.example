# Stripe API Keys
# 將此文件複製為 .env 並填入你的真實 API Keys

# 測試環境（開發時使用）
STRIPE_SECRET_KEY=sk_test_你的測試密鑰
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_你的測試公鑰

# 生產環境（上線時使用）
# STRIPE_SECRET_KEY=sk_live_你的生產密鑰
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_你的生產公鑰

# Webhook Secret（可選，用於接收支付狀態更新）
# STRIPE_WEBHOOK_SECRET=whsec_你的Webhook密鑰
